# Copy this file to .env and fill in real values for local (native) development.
# Docker uses .env.dev / .env.prod instead — see .env.dev.example.

# Flask session signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_with_python_secrets_token_hex_32

# PostgreSQL connection string. Match POSTGRES_USER / POSTGRES_PASSWORD in .env.dev.
# NOTE: URL-encode passwords containing URI-reserved characters (@ : / # ? etc.)
#       e.g. 'p@ss:word' → 'p%40ss%3Aword'. The app auto-encodes on startup, but
#       encoding it here avoids any edge-case parsing surprises.
DATABASE_URL=postgresql://jobmatcher:changeme_dev@localhost:5432/jobmatcher_dev

# Optional — only set if you want to run ingest.py natively.
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=

# Optional — used by templates for the status bar footer.
APP_ENV=local
APP_VERSION=local
