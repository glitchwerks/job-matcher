{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Web UI",
      "type": "shell",
      "command": "python app.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "job-matcher"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run Ingestion",
      "type": "shell",
      "command": "python ingest.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "job-matcher"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Job Matcher",
      "dependsOn": ["Start Web UI"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
