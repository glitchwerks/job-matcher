# Prod environment credentials — copy to .env.prod and fill in values
POSTGRES_USER=jobmatcher
POSTGRES_PASSWORD=changeme_prod
POSTGRES_DB=jobmatcher_prod
# Required: stable secret key for Flask session signing. A new random key on
# every restart invalidates all session cookies and breaks CSRF protection.
# Generate once with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_with_python_secrets_token_hex_32
